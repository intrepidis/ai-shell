{
  "model": {
    "name": "auto-gemini-3"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .gemini/check_models.py",
            "name": "Check for New Models",
            "is_background": true
          }
        ]
      }
    ]
  },
  "general": {
    "defaultApprovalMode": "auto_edit",
    "plan": {
      "enabled": false
    }
  },
  "ui": {
    "hideBanner": true
  }
}